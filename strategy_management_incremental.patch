+            name: str,
+            description: str,
+            asset_type: str,
+            enabled: bool,
+            entry_outer: str,
+            exit_outer: str,
+            initial_stop_enabled: bool,
+            initial_stop_period: int | float,
+            initial_stop_multiple: int | float,
+            trailing_stop_enabled: bool,
