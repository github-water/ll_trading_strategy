+                        "initial_atr_stop": {
+                            "enabled": initial_stop_enabled,
+                            "period": int(initial_stop_period),
+                            "multiple": float(initial_stop_multiple),
+                        },
+                        "trailing_atr_stop": {
+                            "enabled": trailing_stop_enabled,
+                            "period": int(trailing_stop_period),
